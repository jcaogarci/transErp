# =============================================
# TransERP - Variables de entorno
# Copia este archivo como .env y rellena los valores
# =============================================

# Base de datos PostgreSQL (Supabase o Railway)
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_db

# JWT Secret (genera uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=cambia_esto_por_un_secreto_aleatorio_muy_largo

# Puerto del servidor (Render/Railway lo pone automáticamente)
PORT=3000

# Entorno
NODE_ENV=production

# URL del frontend (para CORS) - pon tu dominio de Render
FRONTEND_URL=https://tu-app.onrender.com
